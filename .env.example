# Optional: API keys for premium news sources
# NEWSAPI_KEY=your_newsapi_key
# RAPIDAPI_KEY=your_rapidapi_key  # For Wall Street Fear & Greed (CNN index)
# TWITTER_BEARER_TOKEN=your_x_api_bearer  # Optional: Trump X tweets (paid). Truth Social RSS is free.

# Optional: Daily auto-run (default: 2 PM UTC). Set to disable.
# DISABLE_SCHEDULED_PIPELINE=false
# PIPELINE_SCHEDULE_HOUR=14
# PIPELINE_SCHEDULE_MINUTE=0
